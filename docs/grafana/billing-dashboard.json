{
  "title": "tcreditaim Billing Observability",
  "uid": "billing-observability",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "tags": ["billing", "tcreditaim"],
  "timezone": "browser",
  "time": {"from": "now-6h", "to": "now"},
  "refresh": "30s",
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "label": "Prometheus",
        "query": "prometheus",
        "current": {"text": "Prometheus", "value": "Prometheus"}
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Bill query latency p95 (s)",
      "description": "p95 of HTTP server duration for /api/billing/* endpoints.",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"x": 0, "y": 0, "w": 12, "h": 8},
      "fieldConfig": {
        "defaults": {"unit": "s", "thresholds": {"mode": "absolute", "steps": [{"color": "green"}, {"color": "orange", "value": 1}, {"color": "red", "value": 2}]}}
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le, http_route) (rate(http_server_request_duration_seconds_bucket{http_route=~\"/api/billing/.*\"}[5m])))",
          "legendFormat": "{{http_route}}"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Bill query QPS",
      "description": "Per-route request rate across /api/billing/*.",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"x": 12, "y": 0, "w": 12, "h": 8},
      "fieldConfig": {"defaults": {"unit": "reqps"}},
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (http_route) (rate(http_server_request_duration_seconds_count{http_route=~\"/api/billing/.*\"}[1m]))",
          "legendFormat": "{{http_route}}"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Billing job failures (1h)",
      "description": "billing_job_failure_total increments emitted by service.finishJobFailed.",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"x": 0, "y": 8, "w": 8, "h": 6},
      "fieldConfig": {
        "defaults": {"unit": "short", "thresholds": {"mode": "absolute", "steps": [{"color": "green"}, {"color": "orange", "value": 1}, {"color": "red", "value": 3}]}}
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(billing_job_failure_total[1h]))"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "cost_missing rows inserted (1h)",
      "description": "bill_daily_full rows written with cost_missing=true (channel_pricing miss).",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"x": 8, "y": 8, "w": 8, "h": 6},
      "fieldConfig": {
        "defaults": {"unit": "short", "thresholds": {"mode": "absolute", "steps": [{"color": "green"}, {"color": "orange", "value": 10}, {"color": "red", "value": 100}]}}
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(bill_daily_full_cost_missing_count[1h]))"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Bill query error ratio",
      "description": "5xx ratio for /api/billing/* — used to gate API health.",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"x": 16, "y": 8, "w": 8, "h": 6},
      "fieldConfig": {"defaults": {"unit": "percentunit", "min": 0, "max": 1}},
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(http_server_request_duration_seconds_count{http_route=~\"/api/billing/.*\", http_response_status_code=~\"5..\"}[5m])) / sum(rate(http_server_request_duration_seconds_count{http_route=~\"/api/billing/.*\"}[5m]))",
          "legendFormat": "5xx ratio"
        }
      ]
    }
  ]
}
